PORT=4000
APP_ORIGIN=http://localhost:3000
INSFORGE_URL=https://your-appkey.us-east.insforge.app
INSFORGE_ANON_KEY=your-insforge-anon-key
INSFORGE_API_KEY=your-insforge-api-key

# URL publica HTTPS de este backend. Mercado Pago la usa para webhooks.
PUBLIC_API_URL=https://api.your-domain.com

# URLs de retorno despues de Mercado Pago. Pueden ser deep links/app links.
PAYMENT_SUCCESS_URL=tokeplus://payments/mercadopago/success
PAYMENT_FAILURE_URL=tokeplus://payments/mercadopago/failure
PAYMENT_PENDING_URL=tokeplus://payments/mercadopago/pending

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-token
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# Model Gateway: copia la API key de OpenRouter desde el dashboard de InsForge.
# Sin esto, las rutas /api/ai/* responden 503 (la app igual arranca).
OPENROUTER_API_KEY=

# Secret opcional para proteger POST /api/notifications/process (cron).
NOTIFICATIONS_CRON_SECRET=
